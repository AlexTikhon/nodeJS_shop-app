<%- include('../includes/head.ejs') %>
<%- include('../includes/navigation.ejs') %>

<main class="centered auth-page">
  <h1>Login</h1>

  <% if (errorMessage) { %>
    <div class="message-box message-box--error"><%= errorMessage %></div>
  <% } %>

  <% if (successMessage) { %>
    <div class="message-box message-box--success"><%= successMessage %></div>
  <% } %>

  <form class="product-form login-form" action="/login" method="POST">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <div class="form-control">
      <label for="email">E-Mail</label>
      <input
        class="<%= validationErrors.find(error => error.path === 'email' || error.param === 'email') ? 'invalid' : '' %>"
        type="email"
        name="email"
        id="email"
        value="<%= oldInput.email %>"
        required
      />
    </div>

    <div class="form-control">
      <label for="password">Password</label>
      <input
        class="<%= validationErrors.find(error => error.path === 'password' || error.param === 'password') ? 'invalid' : '' %>"
        type="password"
        name="password"
        id="password"
        value="<%= oldInput.password %>"
        required
      />
    </div>

    <button class="btn" type="submit">Login</button>
  </form>

  <p class="auth-switch"><a href="/reset">Forgot password?</a></p>
  <p class="auth-switch">No account yet? <a href="/signup">Create one</a></p>
</main>

<%- include('../includes/end.ejs') %>
