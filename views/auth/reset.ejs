<%- include('../includes/head.ejs') %>
<%- include('../includes/navigation.ejs') %>

<main class="centered auth-page">
  <h1>Reset Password</h1>

  <% if (errorMessage) { %>
    <div class="message-box message-box--error"><%= errorMessage %></div>
  <% } %>

  <% if (successMessage) { %>
    <div class="message-box message-box--success"><%= successMessage %></div>
  <% } %>

  <form class="product-form login-form" action="/reset" method="POST">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <div class="form-control">
      <label for="email">E-Mail</label>
      <input type="email" name="email" id="email" required />
    </div>

    <button class="btn" type="submit">Send Reset Link</button>
  </form>
</main>

<%- include('../includes/end.ejs') %>
