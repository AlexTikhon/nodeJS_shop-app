<%- include('../includes/head.ejs') %>
<%- include('../includes/navigation.ejs') %>

<main class="centered auth-page">
  <h1>Signup</h1>

  <% if (errorMessage) { %>
    <div class="message-box message-box--error"><%= errorMessage %></div>
  <% } %>

  <form class="product-form login-form" action="/signup" method="POST">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <div class="form-control">
      <label for="name">Name</label>
      <input
        class="<%= validationErrors.find(error => error.path === 'name' || error.param === 'name') ? 'invalid' : '' %>"
        type="text"
        name="name"
        id="name"
        value="<%= oldInput.name %>"
        required
      />
    </div>

    <div class="form-control">
      <label for="email">E-Mail</label>
      <input
        class="<%= validationErrors.find(error => error.path === 'email' || error.param === 'email') ? 'invalid' : '' %>"
        type="email"
        name="email"
        id="email"
        value="<%= oldInput.email %>"
        required
      />
    </div>

    <div class="form-control">
      <label for="password">Password</label>
      <input
        class="<%= validationErrors.find(error => error.path === 'password' || error.param === 'password') ? 'invalid' : '' %>"
        type="password"
        name="password"
        id="password"
        value="<%= oldInput.password %>"
        required
      />
    </div>

    <div class="form-control">
      <label for="confirmPassword">Confirm Password</label>
      <input
        class="<%= validationErrors.find(error => error.path === 'confirmPassword' || error.param === 'confirmPassword') ? 'invalid' : '' %>"
        type="password"
        name="confirmPassword"
        id="confirmPassword"
        value="<%= oldInput.confirmPassword %>"
        required
      />
    </div>

    <button class="btn" type="submit">Create Account</button>
  </form>

  <p class="auth-switch">Already have an account? <a href="/login">Login</a></p>
</main>

<%- include('../includes/end.ejs') %>
