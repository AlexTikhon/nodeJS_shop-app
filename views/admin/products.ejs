<%- include('../includes/head.ejs') %>
<%- include('../includes/navigation.ejs') %>

<main>
  <h1 class="centered">Admin Products</h1>

  <% if (prods.length > 0) { %>
    <ul class="grid">
      <% for (const p of prods) { %>
        <li>
          <article class="card product-item">
            <header class="card__header">
              <h1 class="product__title"><%= p.title %></h1>
            </header>
            <div class="card__image">
              <img src="<%= p.imageUrl %>" alt="<%= p.title %>" />
            </div>
            <div class="card__content">
              <h2 class="product__price">$<%= Number(p.price).toFixed(2) %></h2>
              <p class="product__description"><%= p.description %></p>
            </div>
            <div class="card__actions">
              <a href="/admin/edit-product/<%= p.id %>?edit=true" class="btn">Edit</a>
              <form action="/admin/delete-product" method="POST">
                <input type="hidden" name="productId" value="<%= p.id %>" />
                <button class="btn danger" type="submit">Delete</button>
              </form>
            </div>
          </article>
        </li>
      <% } %>
    </ul>
  <% } else { %>
    <h2 class="centered">No products found.</h2>
  <% } %>
</main>

<%- include('../includes/end.ejs') %>
