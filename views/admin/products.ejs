<%- include('../includes/head.ejs') %>
<%- include('../includes/navigation.ejs') %>

<main>
  <h1 class="centered">Admin Products</h1>

  <% if (prods.length > 0) { %>
    <ul class="grid" id="admin-products-list">
      <% for (const p of prods) { %>
        <li class="product-list-item">
          <article class="card product-item">
            <header class="card__header">
              <h1 class="product__title"><%= p.title %></h1>
            </header>
            <div class="card__image">
              <img src="<%= p.imageUrl.startsWith('http') ? p.imageUrl : '/' + p.imageUrl %>" alt="<%= p.title %>" />
            </div>
            <div class="card__content">
              <h2 class="product__price">$<%= Number(p.price).toFixed(2) %></h2>
              <p class="product__description"><%= p.description %></p>
            </div>
            <div class="card__actions">
              <a href="/admin/edit-product/<%= p._id %>?edit=true" class="btn">Edit</a>
              <form
                action="/admin/delete-product"
                method="POST"
                class="js-delete-product-form"
                data-product-id="<%= p._id %>"
                data-csrf="<%= csrfToken %>"
              >
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="productId" value="<%= p._id %>" />
                <button class="btn danger" type="submit">Delete</button>
              </form>
            </div>
          </article>
        </li>
      <% } %>
    </ul>
  <% } else { %>
    <h2 class="centered" id="admin-products-empty-state">No products found.</h2>
  <% } %>
</main>

<%- include('../includes/end.ejs') %>
