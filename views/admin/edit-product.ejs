<%- include('../includes/head.ejs') %>
<%- include('../includes/navigation.ejs') %>

<main class="centered">
  <h1><%= editing ? 'Edit Product' : 'Add Product' %></h1>

  <% if (errorMessage) { %>
    <div class="message-box message-box--error"><%= errorMessage %></div>
  <% } %>

  <form
    class="product-form"
    action="<%= editing ? '/admin/edit-product' : '/admin/add-product' %>"
    method="POST"
    enctype="multipart/form-data"
  >
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <% if (editing) { %>
      <input type="hidden" name="productId" value="<%= product._id %>" />
    <% } %>

    <div class="form-control">
      <label for="title">Title</label>
      <input
        class="<%= validationErrors.find(error => error.path === 'title' || error.param === 'title') ? 'invalid' : '' %>"
        type="text"
        id="title"
        name="title"
        required
        value="<%= product.title %>"
      />
    </div>

    <div class="form-control">
      <label for="image">Image</label>
      <input type="file" id="image" name="image" accept="image/png,image/jpg,image/jpeg" />
      <% if (editing && product.imageUrl) { %>
        <p class="form-help">Current image: <a href="<%= product.imageUrl.startsWith('http') ? product.imageUrl : '/' + product.imageUrl %>" target="_blank">open</a></p>
      <% } %>
    </div>

    <div class="form-control">
      <label for="price">Price</label>
      <input
        class="<%= validationErrors.find(error => error.path === 'price' || error.param === 'price') ? 'invalid' : '' %>"
        type="number"
        id="price"
        name="price"
        step="0.01"
        required
        value="<%= product.price %>"
      />
    </div>

    <div class="form-control">
      <label for="description">Description</label>
      <textarea
        class="<%= validationErrors.find(error => error.path === 'description' || error.param === 'description') ? 'invalid' : '' %>"
        id="description"
        name="description"
        rows="4"
        required
      ><%= product.description %></textarea>
    </div>

    <button class="btn" type="submit"><%= editing ? 'Update Product' : 'Add Product' %></button>
  </form>
</main>

<%- include('../includes/end.ejs') %>
